<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:VinhKhanhGuide.Mobile.Models"
    x:Name="MainPageRoot"
    Title="Vinh Khanh Guide">
    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">
        <Label
            Grid.Row="0"
            FontSize="24"
            FontAttributes="Bold"
            Text="Food Stalls" />
        <Label
            Grid.Row="1"
            Text="{Binding ErrorMessage}"
            TextColor="IndianRed"
            IsVisible="{Binding HasError}" />
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Picker
                Title="Preview Language"
                ItemsSource="{Binding SupportedPreviewLanguages}"
                ItemDisplayBinding="{Binding DisplayName}"
                SelectedItem="{Binding SelectedPreviewLanguage}" />
            <Label
                FontSize="13"
                Text="{Binding PreviewStatusText}"
                TextColor="#666666" />
        </VerticalStackLayout>

        <Grid Grid.Row="3">
            <CollectionView
                ItemsSource="{Binding Stalls}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedStall, Mode=TwoWay}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8">
                        <Label
                            HorizontalTextAlignment="Center"
                            Text="No stalls found." />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:StallSummary">
                        <Frame
                            Margin="0,0,0,12"
                            Padding="16"
                            BorderColor="#D9D9D9"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    Text="{Binding Name}" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding Category}" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding AverageRatingText}"
                                    TextColor="#666666" />
                                <Button
                                    Text="Preview TTS"
                                    Clicked="OnPreviewNarrationClicked"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="Start" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}" />
        </Grid>
    </Grid>
</ContentPage>
