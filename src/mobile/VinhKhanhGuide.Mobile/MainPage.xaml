<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:VinhKhanhGuide.Mobile.Models"
    x:Name="MainPageRoot"
    Title="Vinh Khanh Guide">
    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="16">
        <Frame
            x:Name="ExternalEntryBanner"
            Grid.Row="0"
            Padding="12,8"
            BorderColor="Transparent"
            BackgroundColor="{Binding BackgroundColor}"
            HasShadow="False"
            IsVisible="{Binding IsVisible}">
            <Label
                FontSize="13"
                Text="{Binding Message}"
                TextColor="{Binding TextColor}" />
        </Frame>

        <VerticalStackLayout Grid.Row="1" Spacing="4">
            <Label
                FontSize="28"
                FontAttributes="Bold"
                Text="Locations" />
            <Label
                FontSize="14"
                Text="Open a location to explore its story, translation, and narration."
                TextColor="#6F6A63" />
        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="2" Spacing="4">
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="IndianRed"
                IsVisible="{Binding HasError}" />
            <Label
                Text="{Binding NoticeMessage}"
                TextColor="#6F6A63"
                IsVisible="{Binding HasNoticeMessage}" />
        </VerticalStackLayout>
        <VerticalStackLayout
            x:Name="MainToolsStack"
            Grid.Row="3"
            Spacing="10">
            <Picker
                Title="Narration language"
                ItemsSource="{Binding SupportedPreviewLanguages}"
                ItemDisplayBinding="{Binding DisplayName}"
                SelectedItem="{Binding SelectedPreviewLanguage}" />
            <Label
                FontSize="13"
                Text="{Binding PreviewStatusText}"
                TextColor="#6F6A63" />
        </VerticalStackLayout>

        <Grid Grid.Row="4">
            <CollectionView
                ItemsSource="{Binding Stalls}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedStall, Mode=TwoWay}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="28" Spacing="10">
                        <Label
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            Text="{Binding EmptyStateTitle}" />
                        <Label
                            HorizontalTextAlignment="Center"
                            Text="{Binding EmptyStateMessage}"
                            TextColor="#6F6A63" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:StallSummary">
                        <Frame
                            Margin="0,0,0,12"
                            Padding="18"
                            BorderColor="#D9D9D9"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    Text="{Binding Name}" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding Category}" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding AverageRatingText}"
                                    TextColor="#666666" />
                                <Button
                                    Text="Listen"
                                    Clicked="OnPreviewNarrationClicked"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="Start" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}" />
            <Label
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Margin="0,52,0,0"
                FontSize="14"
                Text="{Binding LoadingMessage}"
                TextColor="#6F6A63"
                IsVisible="{Binding IsLoading}" />
        </Grid>
    </Grid>
</ContentPage>
