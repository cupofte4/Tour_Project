<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.Mobile.Views.StallDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:VinhKhanhGuide.Mobile.Models"
    Title="Stall Detail">
    <ScrollView>
        <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="16">
            <ActivityIndicator
                Grid.Row="0"
                HorizontalOptions="Center"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}" />

            <Label
                Grid.Row="1"
                Text="{Binding ErrorMessage}"
                TextColor="IndianRed"
                IsVisible="{Binding HasError}" />

            <VerticalStackLayout
                Grid.Row="2"
                Spacing="12"
                BindingContext="{Binding Stall}">
                <Image
                    HeightRequest="220"
                    Aspect="AspectFill"
                    Source="{Binding ImageUrl}" />
                <Label
                    FontSize="26"
                    FontAttributes="Bold"
                    Text="{Binding Name}" />
                <Label
                    FontSize="15"
                    Text="{Binding Category}" />
                <Label
                    FontSize="15"
                    Text="{Binding AverageRatingText}"
                    TextColor="#666666" />
                <Label
                    FontSize="15"
                    Text="{Binding OpenHours, StringFormat='Open hours: {0}'}" />
                <Label
                    FontSize="16"
                    LineBreakMode="WordWrap"
                    Text="{Binding DescriptionVi}" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
