<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.Mobile.Views.StallDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:VinhKhanhGuide.Mobile.Models"
    x:DataType="viewModels:StallDetailViewModel"
    xmlns:viewModels="clr-namespace:VinhKhanhGuide.Mobile.ViewModels"
    Title="Location Details">
    <ScrollView>
        <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18">
            <Frame
                x:Name="ExternalEntryBanner"
                Grid.Row="0"
                x:DataType="{x:Null}"
                Padding="12,8"
                BorderColor="Transparent"
                BackgroundColor="{Binding BackgroundColor}"
                HasShadow="False"
                IsVisible="{Binding IsVisible}">
                <Label
                    FontSize="13"
                    Text="{Binding Message}"
                    TextColor="{Binding TextColor}" />
            </Frame>

            <VerticalStackLayout
                Grid.Row="1"
                Spacing="8"
                IsVisible="{Binding HasPageStatus}">
                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding HasPageStatus}"
                    IsVisible="{Binding HasPageStatus}" />
                <Label
                    FontSize="14"
                    HorizontalTextAlignment="Center"
                    Text="{Binding PageStatusText}"
                    TextColor="#6F6A63" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="2" Spacing="4">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="IndianRed"
                    IsVisible="{Binding HasError}" />
                <Label
                    Text="{Binding RefreshNoticeMessage}"
                    TextColor="#6F6A63"
                    IsVisible="{Binding HasRefreshNotice}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="3" Spacing="14">
                <Picker
                    Title="Detail language"
                    ItemsSource="{Binding Languages}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedLanguage}" />
                <Label
                    FontSize="13"
                    Text="{Binding TranslationStatusText}"
                    TextColor="#6F6A63"
                    IsVisible="{Binding HasTranslationStatus}" />
                <Label
                    FontSize="13"
                    Text="{Binding TranslationNoticeText}"
                    TextColor="#8C6A2F"
                    IsVisible="{Binding HasTranslationNotice}" />
                <Image
                    HeightRequest="220"
                    Aspect="AspectFill"
                    Source="{Binding Stall.DisplayImageSource}" />
                <Label
                    FontSize="26"
                    FontAttributes="Bold"
                    Text="{Binding DisplayName}" />
                <Label
                    FontSize="15"
                    Text="{Binding Stall.Category}" />
                <Label
                    FontSize="15"
                    Text="{Binding Stall.AverageRatingText}"
                    TextColor="#666666" />
                <Label
                    FontSize="15"
                    Text="{Binding Stall.OpenHours, StringFormat='Open hours: {0}'}" />
                <Label
                    FontSize="16"
                    LineBreakMode="WordWrap"
                    Text="{Binding DisplayDescription}" />
                <HorizontalStackLayout Spacing="10">
                    <Button
                        Text="Listen"
                        Clicked="OnPlayNarrationClicked"
                        IsEnabled="{Binding CanStartNarration}" />
                    <Button
                        Text="Stop"
                        Clicked="OnStopNarrationClicked"
                        IsEnabled="{Binding CanStopNarration}" />
                </HorizontalStackLayout>
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Text="Download for offline use"
                            Clicked="OnDownloadOfflineAudioClicked"
                            IsVisible="{Binding IsOfflineAudioDownloadAvailable}"
                            IsEnabled="{Binding CanDownloadOfflineAudio}" />
                        <Button
                            Text="Remove download"
                            Clicked="OnRemoveOfflineAudioClicked"
                            IsVisible="{Binding HasOfflineAudio}"
                            IsEnabled="{Binding CanRemoveOfflineAudio}" />
                    </HorizontalStackLayout>
                    <Label
                        FontSize="13"
                        Text="{Binding OfflineAudioStatusText}"
                        TextColor="#6F6A63"
                        IsVisible="{Binding HasOfflineAudioStatus}" />
                </VerticalStackLayout>
                <Label
                    Text="{Binding NarrationStatusText}"
                    TextColor="#6F6A63"
                    IsVisible="{Binding HasNarrationStatus}" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
