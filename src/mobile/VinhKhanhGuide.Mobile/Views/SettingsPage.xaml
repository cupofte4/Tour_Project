<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.Mobile.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="22"
                Text="Playback &amp; Location" />

            <Label
                Text="{Binding StatusMessage}"
                TextColor="#2E7D32"
                IsVisible="{Binding HasStatusMessage}" />

            <Frame
                Padding="14"
                BorderColor="#D9D9D9"
                CornerRadius="12"
                HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            FontAttributes="Bold"
                            Text="GPS Tracking" />
                        <Switch
                            Grid.Row="0"
                            Grid.Column="1"
                            IsToggled="{Binding IsGpsTrackingEnabled}" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Text="Turn live GPS updates on or off for the map and nearby prompts."
                            TextColor="#666666" />
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            Text="Trigger Radius" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Slider
                                Grid.Column="0"
                                Minimum="0.5"
                                Maximum="2.0"
                                Value="{Binding TriggerRadiusMultiplier}" />
                            <Label
                                Grid.Column="1"
                                VerticalTextAlignment="Center"
                                Text="{Binding TriggerRadiusMultiplierText}" />
                        </Grid>
                        <Label
                            Text="Lower values make nearby triggers calmer. Higher values make them more sensitive."
                            TextColor="#666666" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            FontAttributes="Bold"
                            Text="Auto Narration" />
                        <Switch
                            Grid.Row="0"
                            Grid.Column="1"
                            IsToggled="{Binding AutoNarrationEnabled}" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Text="When enabled, eligible nearby POIs can start narration automatically after the calm gating rules pass."
                            TextColor="#666666" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="14"
                BorderColor="#D9D9D9"
                CornerRadius="12"
                HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        Text="Text to Speech" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Preferred Language" />
                        <Picker
                            ItemsSource="{Binding SupportedLanguages}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Preferred Voice ID (Optional)" />
                        <Entry
                            Placeholder="Leave blank for device default"
                            Text="{Binding PreferredTtsVoiceId}" />
                    </VerticalStackLayout>

                    <Label
                        Text="{Binding SupportNote}"
                        TextColor="#666666"
                        IsVisible="{Binding HasSupportNote}" />
                </VerticalStackLayout>
            </Frame>

            <Button
                Clicked="OnSaveClicked"
                Text="Save Settings" />

            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
