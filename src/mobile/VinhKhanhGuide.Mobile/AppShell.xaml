<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="VinhKhanhGuide.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VinhKhanhGuide.Mobile"
    xmlns:mapViews="clr-namespace:VinhKhanhGuide.Mobile.Views">
    <TabBar>
        <ShellContent
            Title="List"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="main" />
        <ShellContent
            Title="Map"
            ContentTemplate="{DataTemplate mapViews:StallMapPage}"
            Route="map" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate mapViews:SettingsPage}"
            Route="settings" />
    </TabBar>
</Shell>
