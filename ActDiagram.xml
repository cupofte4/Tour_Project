        <mxCell id="end2" value="" style="ellipse;strokeWidth=3;" vertex="1" parent="lane2">
          <mxGeometry x="200" y="780" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- FLOWS -->
        <mxCell edge="1" source="start" target="u1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="u1" target="f1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="f1" target="f2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="f2" target="b1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="b1" target="b2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="b2" target="f3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
