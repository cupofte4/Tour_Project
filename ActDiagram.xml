<mxfile host="app.diagrams.net">
  <diagram name="Activity Diagram Final">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- SWIMLANES -->
        <mxCell id="lane1" value="User" style="swimlane;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="300" height="800" as="geometry"/>
        </mxCell>

        <mxCell id="lane2" value="Frontend (React)" style="swimlane;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="0" width="400" height="800" as="geometry"/>
