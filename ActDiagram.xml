        <mxCell edge="1" source="f4" target="d1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- YES -->
        <mxCell value="Yes" edge="1" source="d1" target="f5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="f5" target="f6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="f6" target="b3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="b3" target="d2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- NO -->
        <mxCell value="No" edge="1" source="d1" target="f7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" source="f7" target="d2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- STOP -->
        <mxCell value="Continue" edge="1" source="d2" target="f4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell value="User Close" edge="1" source="d2" target="end1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell value="GPS Stop" edge="1" source="d2" target="end2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>